# Git Attributes Configuration

# Set default behavior to automatically normalize line endings
* text=auto

# Source code
*.dart text
*.py text
*.md text
*.txt text
*.yaml text
*.yml text
*.json text
*.xml text
*.html text
*.css text
*.js text
*.sh text eol=lf
*.bat text eol=crlf

# Documentation
*.markdown text
*.mdx text
README text
LICENSE text
AUTHORS text
CHANGELOG text
CONTRIBUTING text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp4 binary
*.mov binary
*.avi binary
*.pdf binary
*.zip binary
*.7z binary
*.gz binary
*.tar binary

# ML Models (binary)
*.pkl binary
*.joblib binary
*.h5 binary
*.model binary
*.pt binary
*.pth binary

# Archives
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.rar binary

# Excel files
*.xlsx binary
*.xls binary
*.csv text

# Android specific
*.apk binary
*.aab binary
*.dex binary
*.so binary

# iOS specific
*.ipa binary
*.framework binary

# Generated files
*.class binary
*.jar binary
*.war binary

# Fonts
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary

# Configuration files
.gitignore text
.gitattributes text
.editorconfig text

# Export ignore files
.gitattributes export-ignore
.gitignore export-ignore
.github export-ignore

# Diff settings for specific file types
*.dart diff=dart
*.py diff=python
*.md diff=markdown

# Linguist language overrides (for GitHub language statistics)
*.md linguist-detectable
*.ipynb linguist-documentation
docs/* linguist-documentation

# Mark generated files
*.g.dart linguist-generated=true
*.freezed.dart linguist-generated=true
*.pb.dart linguist-generated=true
*.pbenum.dart linguist-generated=true
*.pbgrpc.dart linguist-generated=true
*.pbjson.dart linguist-generated=true

# Merge strategies
*.json merge=union
*.yaml merge=union
*.yml merge=union
