# Root .gitignore for Egg Gender Prediction System

# OS Files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Temporary Files
*.tmp
*.temp
*.log
*.cache
*.bak
*.old

# Personal Notes
*.txt
!requirements.txt
!requirements_rpi.txt

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/

# Flutter/Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/
*.g.dart
*.freezed.dart

# Firebase
firebase_app_check_debug_token.txt

# ML Models (large files - manage with Git LFS)
# Now managed by Git LFS - see .gitattributes
!*.pkl
!*.joblib
!*.h5
!*.model

# Datasets (usually large) - EXCEPT in ml-models folder
# *.xlsx
# *.csv
# *.xls
# !example_dataset.xlsx
# NOTE: ml-models folder is tracked in Git

# HTML downloads (general) - EXCEPT in ml-models folder
# *.html
# NOTE: ml-models documentation is tracked in Git

# Media Files (manage large files separately)
# *.mp4
# *.mov
# *.avi

# Detection History
detection_history.json

# Build outputs
dist/
*.egg-info/

# Jupyter Notebook (general) - EXCEPT in ml-models folder
.ipynb_checkpoints/
# *.ipynb
# NOTE: ml-models notebooks are tracked in Git

# Credentials and Secrets
google-services.json
GoogleService-Info.plist
firebase_options.dart
.env
*.pem
*.key
credentials.json

# Raspberry Pi specific
local.properties
egg-gender-prediction
